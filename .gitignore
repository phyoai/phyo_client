# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# local tooling / workspace state
/.claude/settings.local.json
/.claude/worktrees/
/.git-rewrite/
/.vscode/
.mcp.json

# testing
/coverage
.nyc_output/
playwright-report/
test-results/

# next.js
/.next/
/out/
.next-cache-state.json
/.turbo/

# production
/build

# misc
.DS_Store
*.pem
*.log
*.tmp
*.cache

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (NEVER commit - contains secrets!)
.env
.env.local
.env.production.local
.env.development.local
.env.test.local
.env*.local

# Secrets and credentials
.aws/
.ssh/
*.key
*.pem
*.p12
*.cert

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
